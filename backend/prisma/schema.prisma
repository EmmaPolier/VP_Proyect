// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CATÁLOGOS / REFERENCE TABLES (11)
// ============================================================================

model EstadoUsuario {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  usuarios    Usuario[]

  @@map("ESTADO_USUARIO")
}

model EstadoVehiculo {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  devices     Device[]

  @@map("ESTADO_VEHICULO")
}

model EstadoRuta {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  rutas       Ruta[]

  @@map("ESTADO_RUTA")
}

model EstadoSolicitud {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  solicitudes SolicitudCupo[]

  @@map("ESTADO_SOLICITUD")
}

model EstadoCur {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  cupones     CupoRuta[]

  @@map("ESTADO_CUR")
}

model TipoTransaccion {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  transacciones TransaccionesCartera[]

  @@map("TIPO_TRANSACCION")
}

model MetodoPago {
  id     Int     @id @default(autoincrement())
  nombre String  @unique

  solicitudes SolicitudCupo[]

  @@map("METODO_PAGO")
}

model MarcaVehiculo {
  id     Int     @id @default(autoincrement())
  nombre String  @unique

  devices Device[]

  @@map("MARCA_VEHICULO")
}

model ModeloVehiculo {
  id     Int     @id @default(autoincrement())
  nombre String
  anio   Int

  devices Device[]

  @@map("MODELO_VEHICULO")
}

model ColorVehiculo {
  id     Int     @id @default(autoincrement())
  nombre String  @unique

  devices Device[]

  @@map("COLOR_VEHICULO")
}

model Perfil {
  id            Int     @id @default(autoincrement())
  nombre        String  @unique
  descripcion   String?
  fechaCreacion DateTime @default(now())

  usuariosPerfil UsuarioPerfil[]
  menuPerfil     MenuPerfil[]

  @@map("PERFIL")
}

// ============================================================================
// MENU & PERMISSIONS (2)
// ============================================================================

model Menu {
  id      Int     @id @default(autoincrement())
  url     String
  nombre  String
  idPadre Int?
  orden   Int

  menuPadre  Menu?         @relation("MenuParent", fields: [idPadre], references: [id])
  menus      Menu[]        @relation("MenuParent")
  perfiles   MenuPerfil[]

  @@map("MENU")
}

model MenuPerfil {
  idMenu    Int
  idPerfil  Int
  insertar  String  // 'S' o 'N'
  actualizar String  // 'S' o 'N'
  eliminar  String   // 'S' o 'N'
  consultar String   // 'S' o 'N'

  menu    Menu   @relation(fields: [idMenu], references: [id])
  perfil  Perfil @relation(fields: [idPerfil], references: [id])

  @@id([idMenu, idPerfil])
  @@map("MENU_PERFIL")
}

// ============================================================================
// USUARIOS & AUTHENTICATION (3)
// ============================================================================

model Usuario {
  documentoUsu        String    @id                    // Cédula/Documento
  nombresUsu          String
  primerApellidoUsu   String
  segundoApellidoUsu  String?
  correoUsu           String    @unique
  numeroTelefonoUsu   String    @unique
  fechaNacimientoUsu  DateTime
  contrasenaUsu       String
  fotoUrlUsu          String
  saldoCarteraUsu     BigInt    @default(0)           // En centavos
  fechaCreacionUsu    DateTime  @default(now())
  updatedAtUsu        DateTime  @updatedAt
  idEstUsu            Int       @default(1)

  // FK
  estado              EstadoUsuario @relation(fields: [idEstUsu], references: [id])

  // Relaciones
  vehiculos           Device[]
  verificaciones      VerificacionCorreo[]
  perfiles            UsuarioPerfil[]
  transacciones       TransaccionesCartera[]
  viajesHistorial     HistorialViaje[]
  calificacionesHechas Calificacion[] @relation("Calificador")
  calificacionesRecibidas Calificacion[] @relation("Calificado")

  @@map("USUARIO")
}

model VerificacionCorreo {
  idVer              Int       @id @default(autoincrement())
  documentoUsuVer    String
  codigoVer          String    @unique
  fechaExpiracionVer DateTime
  usadoVer           String    @default("N")        // 'S' o 'N'
  fechaCreacionVer   DateTime  @default(now())

  usuario            Usuario   @relation(fields: [documentoUsuVer], references: [documentoUsu], onDelete: Cascade)

  @@map("VERIFICACION_CORREO")
}

model UsuarioPerfil {
  idUsp              Int       @id @default(autoincrement())
  documentoUsuUsp    String
  idPerUsp           Int
  calificacionUsu    BigInt    @default(500)        // 5.0 en centavos de punto
  fechaAsignacionUsp DateTime  @default(now())

  usuario            Usuario   @relation(fields: [documentoUsuUsp], references: [documentoUsu], onDelete: Cascade)
  perfil             Perfil    @relation(fields: [idPerUsp], references: [id])
  rutas              Ruta[]
  solicitudes        SolicitudCupo[]

  @@map("USUARIO_PERFIL")
}

// ============================================================================
// VEHICLES (1)
// ============================================================================

model Device {
  idVeh             Int       @id @default(autoincrement())
  placaVeh          String    @unique
  documentoUsuVeh   String
  idMarVeh          Int
  idModVeh          Int
  idColVeh          Int
  idEstVeh          Int
  licenciaUrlVeh    String
  vehiculoUrlVeh    String
  licTransitoUrlVeh String
  soatUrlVeh        String
  fechaRegistroVeh  DateTime  @default(now())
  updatedAtVeh      DateTime  @updatedAt

  // FKs
  usuario           Usuario        @relation(fields: [documentoUsuVeh], references: [documentoUsu], onDelete: Cascade)
  marca             MarcaVehiculo  @relation(fields: [idMarVeh], references: [id])
  modelo            ModeloVehiculo @relation(fields: [idModVeh], references: [id])
  color             ColorVehiculo  @relation(fields: [idColVeh], references: [id])
  estado            EstadoVehiculo @relation(fields: [idEstVeh], references: [id])

  // Relaciones
  rutas             Ruta[]

  @@map("VEHICULO")
}

// ============================================================================
// ROUTES (2)
// ============================================================================

model Ruta {
  idRut              Int       @id @default(autoincrement())
  placaVehRut        Int                            // FK a VEHICULO.idVeh
  idUspRut           Int                            // FK a USUARIO_PERFIL
  latitudOrigenRut   BigInt                         // NUMBER(9,6)
  longitudOrigenRut  BigInt                         // NUMBER(9,6)
  latitudDestinoRut  BigInt                         // NUMBER(9,6)
  longitudDestinoRut BigInt                         // NUMBER(9,6)
  horaSalidaRut      DateTime
  cuposTotalesRut    Int                            // 1-4
  cuposDisponiblesRut Int                           // 0-cuposTotales
  precioCupoRut      BigInt                         // En centavos
  distanciaKmRut     BigInt                         // En metros (para precisión)
  idEstRut           Int
  fechaCreacionRut   DateTime  @default(now())
  updatedAtRut       DateTime  @updatedAt

  // FKs
  vehiculo           Device        @relation(fields: [placaVehRut], references: [idVeh])
  conductor          UsuarioPerfil @relation(fields: [idUspRut], references: [idUsp])
  estado             EstadoRuta    @relation(fields: [idEstRut], references: [id])

  // Relaciones
  puntosEncuentro    PuntoEncuentro[]
  solicitudes        SolicitudCupo[]
  cupones            CupoRuta[]

  @@map("RUTA")
}

model PuntoEncuentro {
  idPun       Int
  idRutPun    Int
  latitudPun  BigInt         // NUMBER(9,6)
  longitudPun BigInt         // NUMBER(9,6)
  ordenPun    Int

  ruta        Ruta    @relation(fields: [idRutPun], references: [idRut], onDelete: Cascade)

  @@id([idPun, idRutPun])
  @@map("PUNTO_ENCUENTRO")
}

// ============================================================================
// SOLICITUDES & CUPONES (2)
// ============================================================================

model SolicitudCupo {
  idSol       Int    @id @default(autoincrement())
  idRutSol    Int
  idUspSol    Int
  idEssSol    Int
  idMpaSol    Int
  montoSol    BigInt // En centavos
  fechaCreacionSol DateTime @default(now())

  // FKs
  ruta        Ruta               @relation(fields: [idRutSol], references: [idRut])
  pasajero    UsuarioPerfil      @relation(fields: [idUspSol], references: [idUsp])
  estado      EstadoSolicitud    @relation(fields: [idEssSol], references: [id])
  metodoPago  MetodoPago         @relation(fields: [idMpaSol], references: [id])

  // Relaciones
  cupones     CupoRuta[]
  calificaciones Calificacion[]

  @@map("SOLICITUD_CUPO")
}

model CupoRuta {
  idSolCrp    Int
  idRutCrp    Int
  idCurCrp    Int

  solicitud   SolicitudCupo  @relation(fields: [idSolCrp], references: [idSol], onDelete: Cascade)
  ruta        Ruta           @relation(fields: [idRutCrp], references: [idRut], onDelete: Cascade)
  estado      EstadoCur      @relation(fields: [idCurCrp], references: [id])
  viajes      HistorialViaje[]
  calificaciones Calificacion[]

  @@id([idSolCrp, idRutCrp])
  @@map("CUPO_RUTA")
}

// ============================================================================
// TRANSACTIONS (1)
// ============================================================================

model TransaccionesCartera {
  idTra              Int    @id @default(autoincrement())
  documentoUsuTra    String
  idTitTra           Int
  montoTra           BigInt // En centavos
  saldoResultanteTra BigInt // En centavos
  fechaRealizacionTra DateTime @default(now())

  // FKs
  usuario            Usuario         @relation(fields: [documentoUsuTra], references: [documentoUsu], onDelete: Cascade)
  tipoTransaccion    TipoTransaccion @relation(fields: [idTitTra], references: [id])

  @@map("TRANSACCIONES_CARTERA")
}

// ============================================================================
// HISTORY & RATINGS (2)
// ============================================================================

model HistorialViaje {
  idHis            Int    @id @default(autoincrement())
  documentoUsuHis  String
  idSolHis         Int
  idRutHis         Int
  rolViajeHis      String // 'CONDUCTOR' o 'PASAJERO'
  costoHis         BigInt // En centavos
  fechaCreacionHis DateTime @default(now())

  // FKs
  usuario          Usuario   @relation(fields: [documentoUsuHis], references: [documentoUsu], onDelete: Cascade)
  cupo             CupoRuta  @relation(fields: [idSolHis, idRutHis], references: [idSolCrp, idRutCrp])

  // Relaciones
  calificaciones   Calificacion[]

  @@unique([idSolHis, idRutHis])
  @@map("HISTORIAL_VIAJE")
}

model Calificacion {
  idCal                Int    @id @default(autoincrement())
  idSolCal             Int
  documentoCalificadorCal String
  documentoCalificadoCal  String
  rolCalificadorCal    String // 'CONDUCTOR' o 'PASAJERO'
  puntajeCal           BigInt // En centavos (0-500 = 0.0-5.0)
  comentarioCal        String?
  fechaCreacionCal     DateTime @default(now())
  idSolCrpCal          Int
  idRutCrpCal          Int
  idHisCal             Int

  // FKs
  solicitud            SolicitudCupo  @relation(fields: [idSolCal], references: [idSol])
  calificador          Usuario        @relation("Calificador", fields: [documentoCalificadorCal], references: [documentoUsu])
  calificado           Usuario        @relation("Calificado", fields: [documentoCalificadoCal], references: [documentoUsu])
  cupo                 CupoRuta       @relation(fields: [idSolCrpCal, idRutCrpCal], references: [idSolCrp, idRutCrp])
  viaje                HistorialViaje @relation(fields: [idHisCal], references: [idHis])

  @@map("CALIFICACION")
}

