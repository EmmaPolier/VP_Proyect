# Backend Environment Variables (.env)
# Copia este archivo como .env y modifica los valores según necesites

NODE_ENV=development
PORT=4000

# Database - SQLite para desarrollo local
# Para Oracle: oracle://c##vamonospues:password@localhost:1521/XE
DATABASE_URL="file:./vamonospues.db"

# JWT Secret - CAMBIAR EN PRODUCCIÓN
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# Email Configuration (Gmail o tu proveedor)
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_app
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
